{
  "number": 25,
  "name_zh": "无妄",
  "name_full": "天雷无妄",
  "structure": "乾上震下",
  "judgment": "元，亨，利，贞。其匪正有眚，不利有攸往。",
  "lines": [
    {
      "position": "初九",
      "text": "无妄，往吉。"
    },
    {
      "position": "六二",
      "text": "不耕获，不菑畲，则利用攸往。"
    },
    {
      "position": "六三",
      "text": "无妄之灾，或系之牛，行人之得，邑人之灾。"
    },
    {
      "position": "九四",
      "text": "可贞。无咎。"
    },
    {
      "position": "九五",
      "text": "无妄之疾，勿药有喜。"
    },
    {
      "position": "上九",
      "text": "无妄，行有眚，无攸利。"
    }
  ],
