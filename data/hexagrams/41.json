{
  "number": 41,
  "name_zh": "损",
  "name_full": "山泽损",
  "structure": "艮上兑下",
  "judgment": "有孚，元吉，无咎，可贞，利有攸往？曷之用，二簋可用享。",
  "lines": [
    {
      "position": "初九",
      "text": "已事遄往，无咎。酌损之。"
    },
    {
      "position": "九二",
      "text": "利贞，征凶，弗损益之。"
    },
    {
      "position": "六三",
      "text": "三人行，则损一人；一人行，则得其友。"
    },
    {
      "position": "六四",
      "text": "损其疾，使遄有喜，无咎。"
    },
    {
      "position": "六五",
      "text": "或益之，十朋之龟弗克违，元吉。"
    },
    {
      "position": "上九",
      "text": "弗损益之，无咎，贞吉，利有攸往，得臣无家。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}