{
  "number": 2,
  "name_zh": "坤",
  "name_full": "坤为地",
  "structure": "坤上坤下",
  "judgment": "元亨，利牝马之贞。君子有攸往，先迷后得主，利；西南得朋，东北丧朋，安贞吉。",
  "lines": [
    {
      "position": "初六",
      "text": "履霜，坚冰至。"
    },
    {
      "position": "六二",
      "text": "直，方，大；不习，无不利。"
    },
    {
      "position": "六三",
      "text": "含章，可贞。或从王事，无成有终。"
    },
    {
      "position": "六四",
      "text": "括囊，无咎无誉。"
    },
    {
      "position": "六五",
      "text": "黄裳，元吉。"
    },
    {
      "position": "上六",
      "text": "龙战于野，其血玄黄。"
    }
  ],
  "yong": "用六：利永贞。",
