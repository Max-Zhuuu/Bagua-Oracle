{
  "number": 42,
  "name_zh": "益",
  "name_full": "风雷益",
  "structure": "巽上震下",
  "judgment": "利有攸往，利涉大川。",
  "lines": [
    {
      "position": "初九",
      "text": "利用为大作，元吉，无咎。"
    },
    {
      "position": "六二",
      "text": "或益之，十朋之龟弗克违，永贞吉。王用享于帝，吉。"
    },
    {
      "position": "六三",
      "text": "益之用凶事，无咎。有孚中行，告公用圭。"
    },
    {
      "position": "六四",
      "text": "中行，告公从。利用为依迁国。"
    },
    {
      "position": "九五",
      "text": "有孚惠心，勿问元吉。有孚惠我德。"
    },
    {
      "position": "上九",
      "text": "莫益之，或击之，立心勿恒，凶。"
    }
  ],
  "yong": null,
