{
  "number": 34,
  "name_zh": "大壮",
  "name_full": "雷天大壮",
  "structure": "震上乾下",
  "judgment": "利贞。",
  "lines": [
    {
      "position": "初九",
      "text": "壮于趾，征凶，有孚。"
    },
    {
      "position": "九二",
      "text": "贞吉。"
    },
    {
      "position": "九三",
      "text": "小人用壮，君子用罔，贞厉。羝羊触藩，羸其角。"
    },
    {
      "position": "九四",
      "text": "贞吉，悔亡。藩决不羸，壮于大舆之輹。"
    },
    {
      "position": "六五",
      "text": "丧羊于易，无悔。"
    },
    {
      "position": "上六",
      "text": "羝羊触藩，不能退，不能遂，无攸利，艰则吉。"
    }
  ],
  "yong": null,
