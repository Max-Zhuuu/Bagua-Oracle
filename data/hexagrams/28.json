{
  "number": 28,
  "name_zh": "大过",
  "name_full": "泽风大过",
  "structure": "兑上巽下",
  "judgment": "栋挠，利有攸往，亨。",
  "lines": [
    {
      "position": "初六",
      "text": "藉用白茅，无咎。"
    },
    {
      "position": "九二",
      "text": "枯杨生稊，老夫得其女妻，无不利。"
    },
    {
      "position": "九三",
      "text": "栋桡，凶。"
    },
    {
      "position": "九四",
      "text": "栋隆，吉；有它吝。"
    },
    {
      "position": "九五",
      "text": "枯杨生华，老妇得其士夫，无咎无誉。"
    },
    {
      "position": "上六",
      "text": "过涉灭顶，凶，无咎。"
    }
  ],
