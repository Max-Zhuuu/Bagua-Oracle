{
  "number": 43,
  "name_zh": "夬",
  "name_full": "泽天夬",
  "structure": "兑上乾下",
  "judgment": "扬于王庭，孚号，有厉，告自邑，不利即戎，利有攸往。",
  "lines": [
    {
      "position": "初九",
      "text": "壮于前趾，往不胜为咎。"
    },
    {
      "position": "九二",
      "text": "惕号，莫夜有戎，勿恤。"
    },
    {
      "position": "九三",
      "text": "壮于頄，有凶。君子夬夬，独行遇雨，若濡有愠，无咎。"
    },
    {
      "position": "九四",
      "text": "臀无肤，其行次且。牵羊悔亡，闻言不信。"
    },
    {
      "position": "九五",
      "text": "苋陆夬夬，中行无咎。"
    },
    {
      "position": "上六",
      "text": "无号，终有凶。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}