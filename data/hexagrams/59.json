{
  "number": 59,
  "name_zh": "涣",
  "name_full": "风水涣",
  "structure": "巽上坎下",
  "judgment": "亨。王假有庙，利涉大川，利贞。",
  "lines": [
    {
      "position": "初六",
      "text": "用拯马壮，吉。"
    },
    {
      "position": "九二",
      "text": "涣奔其机，悔亡。"
    },
    {
      "position": "六三",
      "text": "涣其躬，无悔。"
    },
    {
      "position": "六四",
      "text": "涣其群，元吉。涣有丘，匪夷所思。"
    },
    {
      "position": "九五",
      "text": "涣汗其大号，涣王居，无咎。"
    },
    {
      "position": "上九",
      "text": "涣其血，去逖出，无咎。"
    }
  ],
