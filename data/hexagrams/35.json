{
  "number": 35,
  "name_zh": "晋",
  "name_full": "火地晋",
  "structure": "离上坤下",
  "judgment": "康侯用锡马蕃庶，昼日三接。",
  "lines": [
    {
      "position": "初六",
      "text": "晋如，摧如，贞吉。罔孚，裕无咎。"
    },
    {
      "position": "六二",
      "text": "晋如，愁如，贞吉。受兹介福于，其王母。"
    },
    {
      "position": "六三",
      "text": "众允，悔亡。"
    },
    {
      "position": "九四",
      "text": "晋如鼫鼠，贞厉。"
    },
    {
      "position": "六五",
      "text": "悔亡，失得勿恤，往吉无不利。"
    },
    {
      "position": "上九",
      "text": "晋其角，维用伐邑，厉吉无咎，贞吝。"
    }
  ],
