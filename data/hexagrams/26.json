{
  "number": 26,
  "name_zh": "大畜",
  "name_full": "山天大畜",
  "structure": "艮上乾下",
  "judgment": "利贞，不家食吉，利涉大川。",
  "lines": [
    {
      "position": "初九",
      "text": "有厉利已。"
    },
    {
      "position": "九二",
      "text": "舆说輹。"
    },
    {
      "position": "九三",
      "text": "良马逐，利艰贞。日闲舆卫，利有攸往。"
    },
    {
      "position": "六四",
      "text": "童牛之牿，元吉。"
    },
    {
      "position": "六五",
      "text": "豶豕之牙，吉。"
    },
    {
      "position": "上九",
      "text": "何天之衢，亨。"
    }
  ],
