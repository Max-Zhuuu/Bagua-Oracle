{
  "number": 63,
  "name_zh": "既济",
  "name_full": "水火既济",
  "structure": "坎上离下",
  "judgment": "亨，小利贞，初吉终乱。",
  "lines": [
    {
      "position": "初九",
      "text": "曳其轮，濡其尾，无咎。"
    },
    {
      "position": "六二",
      "text": "妇丧其茀，勿逐，七日得。"
    },
    {
      "position": "九三",
      "text": "高宗伐鬼方，三年克之，小人勿用。"
    },
    {
      "position": "六四",
      "text": "繻有衣袽，终日戒。"
    },
    {
      "position": "九五",
      "text": "东邻杀牛，不如西邻之禴祭，实受其福。"
    },
    {
      "position": "上六",
      "text": "濡其首，厉。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}