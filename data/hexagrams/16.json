{
  "number": 16,
  "name_zh": "豫",
  "name_full": "雷地豫",
  "structure": "震上坤下",
  "judgment": "利建侯，行师。",
  "lines": [
    {
      "position": "初六",
      "text": "鸣豫，凶。"
    },
    {
      "position": "六二",
      "text": "介于石，不终日，贞吉。"
    },
    {
      "position": "六三",
      "text": "盱豫悔；迟有悔。"
    },
    {
      "position": "九四",
      "text": "由豫，大有得，勿疑。朋盍簪。"
    },
    {
      "position": "六五",
      "text": "贞疾，恒不死。"
    },
    {
      "position": "上六",
      "text": "冥豫，成有渝，无咎。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}