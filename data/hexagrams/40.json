{
  "number": 40,
  "name_zh": "解",
  "name_full": "雷水解",
  "structure": "震上坎下",
  "judgment": "利西南，无所往，其来复吉。有攸往，夙吉。",
  "lines": [
    {
      "position": "初六",
      "text": "无咎。"
    },
    {
      "position": "九二",
      "text": "田获三狐，得黄矢，贞吉。"
    },
    {
      "position": "六三",
      "text": "负且乘，致寇至，贞吝。"
    },
    {
      "position": "九四",
      "text": "解而拇，朋至斯孚。"
    },
    {
      "position": "六五",
      "text": "君子维有解，吉；有孚于小人。"
    },
    {
      "position": "上六",
      "text": "公用射隼，于高墉之上，获之，无不利。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}