{
  "number": 12,
  "name_zh": "否",
  "name_full": "地天否",
  "structure": "乾上坤下",
  "judgment": "否之匪人，不利，君子贞；大往小来。",
  "lines": [
    {
      "position": "初六",
      "text": "拔茅茹，以其汇；贞吉，亨。"
    },
    {
      "position": "六二",
      "text": "包承，小人吉；大人否，亨。"
    },
    {
      "position": "六三",
      "text": "包羞。"
    },
    {
      "position": "九四",
      "text": "有命无咎，畴离祉。"
    },
    {
      "position": "九五",
      "text": "休否，大人吉；其亡其亡，系于苞桑。"
    },
    {
      "position": "上九",
      "text": "倾否；先否后喜。"
    }
  ],
  "yong": null,
