{
  "number": 21,
  "name_zh": "噬嗑",
  "name_full": "火雷噬嗑",
  "structure": "离上震下",
  "judgment": "亨。利用狱。",
  "lines": [
    {
      "position": "初九",
      "text": "屦校灭趾，无咎。"
    },
    {
