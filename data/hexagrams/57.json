{
  "number": 57,
  "name_zh": "巽",
  "name_full": "巽为风",
  "structure": "巽上巽下",
  "judgment": "小亨，利有攸往，利见大人。",
  "lines": [
    {
      "position": "初六",
      "text": "进退，利武人之贞。"
    },
    {
      "position": "九二",
      "text": "巽在床下，用史巫纷若吉，无咎。"
    },
    {
      "position": "九三",
      "text": "频巽，吝。"
    },
    {
      "position": "六四",
      "text": "悔亡，田获三品。"
    },
    {
      "position": "九五",
      "text": "贞吉悔亡，无不利。无初有终，先庚三日，后庚三日，吉。"
    },
    {
      "position": "上九",
      "text": "巽在床下，丧其资斧，贞凶。"
    }
  ],
