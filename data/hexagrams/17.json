{
  "number": 17,
  "name_zh": "随",
  "name_full": "泽雷随",
  "structure": "兑上震下",
  "judgment": "元亨，利贞，无咎。",
  "lines": [
    {
      "position": "初九",
      "text": "官有渝，贞吉。出门交有功。"
    },
    {
      "position": "六二",
      "text": "系小子，失丈夫。"
    },
    {
      "position": "六三",
      "text": "系丈夫，失小子；随有求得，利居贞。"
    },
    {
      "position": "九四",
      "text": "随有获，贞凶；有孚在道，以明，何咎。"
    },
    {
      "position": "九五",
      "text": "孚于嘉，吉。"
    },
    {
      "position": "上六",
      "text": "拘系之，乃从，维之；王用亨于西山。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}