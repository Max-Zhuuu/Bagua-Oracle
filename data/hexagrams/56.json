{
  "number": 56,
  "name_zh": "旅",
  "name_full": "火山旅",
  "structure": "离上艮下",
  "judgment": "小亨，旅贞吉。",
  "lines": [
    {
      "position": "初六",
      "text": "旅琐琐，斯其所取灾。"
    },
    {
      "position": "六二",
      "text": "旅即次，怀其资，得童仆贞。"
    },
    {
      "position": "九三",
      "text": "旅焚其次，丧其童仆，贞厉。"
    },
    {
      "position": "九四",
      "text": "旅于处，得其资斧，我心不快。"
    },
    {
      "position": "六五",
      "text": "射雉一矢亡，终以誉命。"
    },
    {
      "position": "上九",
      "text": "鸟焚其巢，旅人先笑，后号啕。丧牛于易，凶。"
    }
  ],
