{
  "number": 3,
  "name_zh": "屯",
  "name_full": "水雷屯",
  "structure": "坎上震下",
  "judgment": "元亨，利贞。勿用有攸往。利建侯。",
  "lines": [
    {
      "position": "初九",
      "text": "磐桓。利居贞。利建侯。"
    },
    {
      "position": "六二",
      "text": "屯如邅如。乘马班如。匪寇。婚媾。女子贞不字，十年乃字。"
    },
    {
      "position": "六三",
      "text": "即鹿无虞，惟入于林中。君子几，不如舍。往，吝。"
    },
    {
      "position": "六四",
      "text": "乘马班如，求婚媾。往，吉。无不利。"
    },
    {
      "position": "九五",
      "text": "屯其膏。小贞吉；大贞凶。"
    },
    {
      "position": "上六",
      "text": "乘马班如，泣血涟如。"
    }
  ],
  "yong": null,
