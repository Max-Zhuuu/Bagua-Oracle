{
  "number": 31,
  "name_zh": "咸",
  "name_full": "泽山咸",
  "structure": "兑上艮下",
  "judgment": "亨，利贞，取女吉。",
  "lines": [
    {
      "position": "初六",
      "text": "咸其拇。"
    },
    {
      "position": "六二",
      "text": "咸其腓，凶，居吉。"
    },
    {
      "position": "九三",
      "text": "咸其股，执其随，往吝。"
    },
    {
      "position": "九四",
      "text": "贞吉悔亡，憧憧往来，朋从尔思。"
    },
    {
      "position": "九五",
      "text": "咸其脢，无悔。"
    },
    {
      "position": "上六",
      "text": "咸其辅，颊，舌。"
    }
  ],
