{
  "number": 15,
  "name_zh": "谦",
  "name_full": "地山谦",
  "structure": "坤上艮下",
  "judgment": "亨。君子有终。",
  "lines": [
    {
      "position": "初六",
      "text": "谦谦君子。用涉大川，吉。"
    },
    {
      "position": "六二",
      "text": "鸣谦，贞吉。"
    },
    {
      "position": "九三",
      "text": "劳谦，君子有终，吉。"
    },
    {
      "position": "六四",
      "text": "无不利，撝谦。"
    },
    {
      "position": "六五",
      "text": "不富，以其邻利用侵伐，无不利。"
    },
    {
      "position": "上六",
      "text": "鸣谦，利用行师、征邑国。"
    }
  ],
