{
  "number": 19,
  "name_zh": "临",
  "name_full": "地泽临",
  "structure": "坤上兑下",
  "judgment": "元，亨，利，贞。至于八月有凶。",
  "lines": [
    {
      "position": "初九",
      "text": "咸临，贞吉。"
    },
    {
      "position": "九二",
      "text": "咸临，吉无不利。"
    },
    {
      "position": "六三",
      "text": "甘临，无攸利。既忧之，无咎。"
    },
    {
      "position": "六四",
      "text": "至临，无咎。"
    },
    {
      "position": "六五",
      "text": "知临，大君之宜，吉。"
    },
    {
      "position": "上六",
      "text": "敦临，吉无咎。"
    }
  ],
