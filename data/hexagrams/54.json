{
  "number": 54,
  "name_zh": "归妹",
  "name_full": "雷泽归妹",
  "structure": "震上兑下",
  "judgment": "征凶，无攸利。",
  "lines": [
    {
      "position": "初九",
      "text": "归妹以娣，跛能履，征吉。"
    },
    {
      "position": "九二",
      "text": "眇能视，利幽人之贞。"
    },
    {
      "position": "六三",
      "text": "归妹以须，反归以娣。"
    },
    {
      "position": "九四",
      "text": "归妹愆期，迟归有时。"
    },
    {
      "position": "六五",
      "text": "帝乙归妹，其君之袂，不如其娣之袂良，月几望，吉。"
    },
    {
      "position": "上六",
      "text": "女承筐无实，士刲羊无血，无攸利。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}