{
  "number": 33,
  "name_zh": "遁",
  "name_full": "天山遁",
  "structure": "乾上艮下",
  "judgment": "《遯》：亨，小利贞。",
  "lines": [
    {
      "position": "初六",
      "text": "遯尾，厉，勿用有攸往。"
    },
    {
      "position": "六二",
      "text": "执之用黄牛之革，莫之胜说。"
    },
    {
      "position": "九三",
      "text": "系遯，有疾厉，畜臣妾吉。"
    },
    {
      "position": "九四",
      "text": "好遯君子吉，小人否。"
    },
    {
      "position": "九五",
      "text": "嘉遯，贞吉。"
    },
    {
      "position": "上九",
      "text": "肥遯，无不利。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}