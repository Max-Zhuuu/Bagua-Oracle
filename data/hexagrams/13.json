{
  "number": 13,
  "name_zh": "同人",
  "name_full": "天火同人",
  "structure": "乾上离下",
  "judgment": "同人于野，亨，利涉大川，利君子贞。",
  "lines": [
    {
      "position": "初九",
      "text": "同人于门，无咎。"
    },
    {
      "position": "六二",
      "text": "同人于宗，吝。"
    },
    {
      "position": "九三",
      "text": "伏戎于莽，升其高陵，三岁不兴。"
    },
    {
      "position": "九四",
      "text": "乘其墉，弗克攻，吉。"
    },
    {
      "position": "九五",
      "text": "同人，先号咷，而后笑，大师克相遇。"
    },
    {
      "position": "上九",
      "text": "同人于郊，无悔。"
    }
  ],
