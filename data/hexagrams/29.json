{
  "number": 29,
  "name_zh": "坎",
  "name_full": "坎为水",
  "structure": "坎上坎下",
  "judgment": "有孚，维心亨，行有尚。",
  "lines": [
    {
      "position": "初六",
      "text": "习坎，入于坎窞，凶。"
    },
    {
      "position": "九二",
      "text": "坎有险，求小得。"
    },
    {
      "position": "六三",
      "text": "来之坎，坎险且枕，入于坎窞，勿用。"
    },
    {
      "position": "六四",
      "text": "樽酒簋贰，用缶，纳约自牖，终无咎。"
    },
    {
      "position": "九五",
      "text": "坎不盈，祗既平，无咎。"
    },
    {
      "position": "上六",
      "text": "系用徽纆，窴于丛棘，三岁不得，凶。"
    }
  ],
  "yong": null,
