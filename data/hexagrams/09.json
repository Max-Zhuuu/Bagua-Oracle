{
  "number": 9,
  "name_zh": "小畜",
  "name_full": "风天小畜",
  "structure": "巽上乾下",
  "judgment": "亨。密云不雨，自我西郊。",
  "lines": [
    {
      "position": "初九",
      "text": "复自道，何其咎？吉。"
    },
    {
      "position": "九二",
      "text": "牵复，吉。"
    },
    {
      "position": "九三",
      "text": "舆说辐，夫妻反目。"
    },
    {
      "position": "六四",
      "text": "有孚，血去惕出，无咎。"
    },
    {
      "position": "九五",
      "text": "有孚挛如，富以其邻。"
    },
    {
      "position": "上九",
      "text": "既雨既处，尚德载；妇贞厉，月几望；君子征凶。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}