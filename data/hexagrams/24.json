{
  "number": 24,
  "name_zh": "复",
  "name_full": "地雷复",
  "structure": "坤上震下",
  "judgment": "亨。出入无疾，朋来无咎。反覆其道，七日来复，利有攸往。",
  "lines": [
    {
      "position": "初九",
      "text": "不远复，无祗悔，元吉。"
    },
    {
      "position": "六二",
      "text": "休复，吉。"
    },
    {
      "position": "六三",
      "text": "频复，厉无咎。"
    },
    {
      "position": "六四",
      "text": "中行独复。"
    },
    {
      "position": "六五",
      "text": "敦复，无悔。"
    },
    {
      "position": "上六",
      "text": "迷复，凶，有灾眚。用行师，终有大败，以其国君，凶；至于十年，不克征。"
    }
  ],
  "yong": null,
