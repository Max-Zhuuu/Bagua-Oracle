{
  "number": 38,
  "name_zh": "睽",
  "name_full": "火泽睽",
  "structure": "离上兑下",
  "judgment": "小事吉。",
  "lines": [
    {
      "position": "初九",
      "text": "悔亡，丧马勿逐，自复；见恶人无咎。"
    },
    {
      "position": "九二",
      "text": "遇主于巷，无咎。"
    },
    {
      "position": "六三",
      "text": "见舆曳，其牛掣，其人天且劓，无初有终。"
    },
    {
      "position": "九四",
      "text": "睽孤，遇元夫，交孚，厉无咎。"
    },
    {
      "position": "六五",
      "text": "悔亡，厥宗噬肤，往何咎？"
    },
    {
      "position": "上九",
      "text": "睽孤，见豕负涂，载鬼一车，先张之弧，后说之弧，匪寇婚媾，往遇雨则吉。"
    }
  ],
  "yong": null,
