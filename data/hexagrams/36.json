{
  "number": 36,
  "name_zh": "明夷",
  "name_full": "地火明夷",
  "structure": "坤上离下",
  "judgment": "利艰贞。",
  "lines": [
    {
      "position": "初九",
      "text": "明夷于飞，垂其翼。君子于行，三日不食，有攸往， 主人有言。"
    },
    {
      "position": "六二",
      "text": "明夷，夷于左股，用拯马壮，吉。"
    },
    {
      "position": "九三",
      "text": "明夷于南狩，得其大首，不可疾贞。"
    },
    {
      "position": "六四",
      "text": "入于左腹，获明夷之心，于出门庭。"
    },
    {
      "position": "六五",
      "text": "箕子之明夷，利贞。"
    },
    {
      "position": "上六",
      "text": "不明晦，初登于天，后入于地。"
    }
  ],
  "yong": null,
