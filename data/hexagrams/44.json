{
  "number": 44,
  "name_zh": "姤",
  "name_full": "天风姤",
  "structure": "乾上巽下",
  "judgment": "女壮，勿用取女。",
  "lines": [
    {
      "position": "初六",
      "text": "系于金柅，贞吉，有攸往，见凶，羸豕孚蹢躅。"
    },
    {
      "position": "九二",
      "text": "包有鱼，无咎，不利宾。"
    },
    {
      "position": "九三",
      "text": "臀无肤，其行次且，厉，无大咎。"
    },
    {
      "position": "九四",
      "text": "包无鱼，起凶。"
    },
    {
      "position": "九五",
      "text": "以杞包瓜，含章，有陨自天。"
    },
    {
      "position": "上九",
      "text": "姤其角，吝，无咎。"
    }
  ],
  "yong": null,
  "tuan": "",
  "xiang": "",
  "wenyan": null
}